{
    "name"             : "espark-react",
    "version"          : "0.6.5",
    "author"           : {
        "name" : "Alan Tai"
    },
    "repository"       : {
        "type" : "git",
        "url"  : "https://github.com/ayltai/espark.git"
    },
    "bugs"             : {
        "url" : "https://github.com/ayltai/espark/issues"
    },
    "keywords"         : [
        "esp32",
        "iot"
    ],
    "license"          : "MIT",
    "module"           : "dist/index.es.js",
    "main"             : "dist/index.cjs.js",
    "types"            : "dist/src/index.d.ts",
    "type"             : "module",
    "exports"          : {
        ".": {
            "import" : "./dist/index.es.js",
            "require" : "./dist/index.cjs.js"
        }
    },
    "files"            : [
        "dist"
    ],
    "scripts"          : {
        "clean"   : "pnpm dlx rimraf --glob **/node_modules/* pnpm-lock.yaml",
        "reset"   : "pnpm clean && pnpm i && pnpm audit -P",
        "lint"    : "eslint src",
        "pretest" : "pnpm lint",
        "test"    : "cross-env VITE_COVERAGE=true vitest --run",
        "test:ci" : "cross-env NODE_OPTIONS=--max-old-space-size=1536 VITE_COVERAGE=true vitest --run",
        "build"   : "vite build && tsc -p tsconfig.build.json"
    },
    "peerDependencies" : {
        "react"     : "^19.2.4",
        "react-dom" : "^19.2.4"
    },
    "dependencies"     : {
        "@ant-design/icons"                 : "^6.1.1",
        "@fortawesome/fontawesome-svg-core" : "^7.2.0",
        "@fortawesome/free-solid-svg-icons" : "^7.2.0",
        "@fortawesome/react-fontawesome"    : "^3.3.0",
        "@refinedev/antd"                   : "^6.0.3",
        "@refinedev/core"                   : "^5.0.12",
        "@refinedev/react-router"           : "^2.0.4",
        "@tanstack/react-query"             : "^5.99.0",
        "antd"                              : "^6.3.5",
        "date-fns"                          : "^4.1.0",
        "i18next"                           : "^26.0.4",
        "react-i18next"                     : "^17.0.3",
        "react-redux"                       : "^9.2.0",
        "react-router"                      : "^7.14.1",
        "string-to-color"                   : "^2.2.2"
    },
    "devDependencies"  : {
        "@eslint/eslintrc"           : "^3.3.5",
        "@eslint/js"                 : "^10.0.1",
        "@refinedev/cli"             : "^2.16.52",
        "@stylistic/eslint-plugin"   : "^5.10.0",
        "@testing-library/jest-dom"  : "^6.9.1",
        "@testing-library/react"     : "^16.3.2",
        "@types/react"               : "^19.2.14",
        "@types/react-dom"           : "^19.2.3",
        "@types/react-test-renderer" : "^19.1.0",
        "@typescript-eslint/parser"  : "^8.58.2",
        "@vitejs/plugin-react-swc"   : "^4.3.0",
        "@vitest/coverage-v8"        : "^4.1.4",
        "@vitest/ui"                 : "^4.1.4",
        "cross-env"                  : "^10.1.0",
        "eslint"                     : "~9.39.4",
        "eslint-plugin-import"       : "^2.32.0",
        "eslint-plugin-prefer-arrow" : "^1.2.3",
        "eslint-plugin-react"        : "^7.37.5",
        "eslint-plugin-react-hooks"  : "^7.0.1",
        "eslint-plugin-unicorn"      : "^64.0.0",
        "globals"                    : "^17.5.0",
        "jsdom"                      : "^29.0.2",
        "prop-types"                 : "^15.8.1",
        "typescript"                 : "~5.9.3",
        "typescript-eslint"          : "^8.58.2",
        "vite"                       : "^8.0.8",
        "vitest"                     : "^4.1.4",
        "vitest-fetch-mock"          : "^0.4.5"
    },
    "resolutions"      : {
        "lodash"         : "^4.18.0",
        "lodash-es"      : "^4.18.0",
        "qs"             : "^6.14.2",
        "path-to-regexp" : "^8.4.0"
    },
    "engines"          : {
        "node" : ">=22",
        "pnpm" : ">=10"
    },
    "publishConfig"    : {
        "access" : "public"
    }
}
